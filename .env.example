# Django Environment
ENVIRONMENT=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=Laguna
DB_USER=postgres
DB_PASSWORD=root
DB_HOST=127.0.0.1
DB_PORT=5432

# Email Configuration (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@laguna-clothing.com

# Email Configuration (Mailgun) - Optional
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain
MAILGUN_FROM_EMAIL=noreply@laguna-clothing.com

# Server Configuration
ALLOWED_HOSTS=localhost,127.0.0.1
PRODUCTION_URL=https://your-production-url.com
SERVER_URL=http://localhost:8000

# Redis Configuration (Optional)
REDIS_BACKEND=redis://127.0.0.1:6379/0

# Frontend URLs (CORS)
# Add your frontend URLs here for CORS configuration
FRONTEND_URL=http://localhost:3000
VITE_SERVER_URL=http://localhost:5173
