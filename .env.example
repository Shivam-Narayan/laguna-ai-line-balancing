# Django Environment Configuration
ENVIRONMENT=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
# for db connection for local
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=your-local-db-name
# DB_USER=your-local-db-user
# DB_PASSWORD=your-local-db-password
# DB_HOST=127.0.0.1
# DB_PORT=5432

# for db connection for local
DB_ENGINE=django.db.backends.postgresql
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_HOST=127.0.0.1
DB_PORT=5432

# for db connection with azure postgress for PRODUCTION
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=your-prod-db-name
# DB_USER=your-prod-db-user
# DB_PASSWORD=your-prod-db-password
# DB_HOST=your-prod-db-host
# DB_PORT=5432

# Allowed Hosts
ALLOWED_HOSTS=127.0.0.1,localhost,your-allowed-hosts

# for sendGrid email configuration
SENDGRID_API_KEY=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=your-default-from-email

# for mailgun email configuration
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=your-mailgun-domain
# MAILGUN_FROM_EMAIL=your-mailgun-from-email

PRODUCTION_URL=https://your-production-url.com
SERVER_URL=http://your-server-url:8000

DEV_FRONTED_URL=http://your-dev-frontend-url # Without scheme 'http' or 'https'
PRODUCTION_FRONTED_URL=https://your-prod-frontend-url # Without scheme 'http' or 'https'

LIST_OF_EMAILS=email1@example.com,email2@example.com

# pgAdmin UI Credentials
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050

# Django Superuser Credentials (For local admin panel access)
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=your-superuser-password

# Docker credentials
DOCKER_USER=your-docker-user
DOCKER_ACCESS_TOKEN=your-docker-access-token

# Redis Configuration (Optional)
REDIS_BACKEND=redis://127.0.0.1:6379/0

# Frontend URLs (Local CORS)
FRONTEND_URL=http://localhost:3000
VITE_SERVER_URL=http://localhost:5173

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION_NAME=your-s3-region-name

# Google SSO Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
